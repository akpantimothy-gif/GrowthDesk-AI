{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "**/.env.local",
    "**/tsconfig.json"
  ],
  "pipeline": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },
    "dev": {
      "cache": false
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "type-check": {
      "dependsOn": [
        "^type-check"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ]
    }
  }
}
