generator client {\n  provider = "prisma-client-js"\n}\n\ndatasource db {\n  provider = "postgresql"\n  url      = env("DATABASE_URL")\n}\n\nmodel User {\n  id         String    @id @default(uuid())\n  email      String    @unique\n  password_hash String\n  full_name  String\n  role       String    @default("bd_manager")\n  department String    @default("business_dev")\n  is_active  Boolean   @default(true)\n  created_at DateTime  @default(now())\n  last_login DateTime?\n  \n  projects   Project[]\n  project_members ProjectMember[]\n  outputs    Output[]\n  \n  @@index([email])\n}\n\nmodel Project {\n  id        String    @id @default(uuid())\n  name      String\n  client_name String?\n  industry  String?\n  status    String    @default("draft")\n  created_by String\n  created_at DateTime @default(now())\n  updated_at DateTime @updatedAt\n  \n  user      User      @relation(fields: [created_by], references: [id])\n  members   ProjectMember[]\n  outputs   Output[]\n  \n  @@index([created_by])\n  @@index([status])\n}\n\nmodel ProjectMember {\n  project_id String\n  user_id    String\n  role       String    @default("editor")\n  \n  project    Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)\n  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)\n  \n  @@id([project_id, user_id])\n  @@index([user_id])\n}\n\nmodel Output {\n  id         String    @id @default(uuid())\n  project_id String\n  module_type String\n  input_data Json\n  output_data Json\n  ai_model   String\n  tokens_used Int\n  generation_time_ms Int\n  is_favorite Boolean @default(false)\n  created_at DateTime @default(now())\n  updated_at DateTime @updatedAt\n  \n  project    Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)\n  user       User?     @relation(fields: [created_by], references: [id])\n  created_by String?\n  \n  @@index([project_id])\n  @@index([module_type])\n  @@index([created_at])\n}\n\nmodel PromptTemplate {\n  id         String    @id @default(uuid())\n  module_type String\n  system_prompt String @db.Text\n  version    Int       @default(1)\n  is_active  Boolean   @default(true)\n  created_by String\n  created_at DateTime  @default(now())\n  \n  @@index([module_type])\n  @@index([is_active])\n}\n